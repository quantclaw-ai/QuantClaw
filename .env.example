# QuantClaw environment variables
# Copy to .env and fill in the values you need. .env is gitignored.
# All keys are optional — QuantClaw only uses the providers you configure.

# ── LLM providers ──
# At least one is required (or run Ollama locally on port 11434).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ── Google OAuth (for Gemini via OAuth instead of API key) ──
# Defaults in source are the public Gemini CLI OAuth client (RFC 8252
# installed-app flow — not a confidential secret). Override only if you
# want to use your own Google Cloud OAuth client.
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=

# ── Data source API keys (all optional) ──
ALPHA_VANTAGE_API_KEY=
EIA_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
NASDAQ_DATA_LINK_API_KEY=
SIMFIN_API_KEY=
TIINGO_API_KEY=
TWELVE_DATA_API_KEY=

# ── Search ──
SEARCH_API_KEY=

# ── Notification channels ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
